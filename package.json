{
  "name": "watch-guilds",
  "version": "1.0.0",
  "description": "Monitoring of emojis, stickers, etc. on the Discord guilds and listing or notifying them in a text channel.",
  "homepage": "https://github.com/jaoafa/watch-guilds",
  "bugs": {
    "url": "https://github.com/jaoafa/watch-guilds/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "output/index.js",
  "repository": {
    "url": "git@github.com:jaoafa/watch-guilds.git",
    "type": "git"
  },
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "fix": "run-z fix:prettier,fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "generate-schema": "typescript-json-schema --required tsconfig.json Configuration -o schema/Configuration.json",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@book000/node-utils": "1.24.278",
    "@types/node": "24.13.3",
    "discord.js": "14.26.4",
    "eslint": "10.6.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-promise": "7.3.0",
    "natsort": "2.0.3",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-json-schema": "0.67.4"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
